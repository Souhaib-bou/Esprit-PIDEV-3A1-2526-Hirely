<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.RoleController"
      spacing="15"
      styleClass="app-root">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- ===== FORM CARD ===== -->
    <VBox spacing="12" styleClass="card">

        <Label text="Role Management" styleClass="section-title"/>

        <GridPane hgap="12" vgap="10">

            <columnConstraints>
                <ColumnConstraints minWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Role Name"/>
            <TextField fx:id="txtRoleName" GridPane.columnIndex="1"/>

            <Label text="Status" GridPane.rowIndex="1"/>
            <ComboBox fx:id="cmbStatus"
                      GridPane.rowIndex="1"
                      GridPane.columnIndex="1"/>

            <Label text="Dashboard" GridPane.rowIndex="2"/>
            <TextField fx:id="txtDashboard"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="1"/>

            <Label text="Description" GridPane.rowIndex="3"/>
            <TextArea fx:id="txtDescription"
                      prefRowCount="3"
                      GridPane.rowIndex="3"
                      GridPane.columnIndex="1"/>
        </GridPane>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Add" onAction="#handleAdd"/>
            <Button text="Update" onAction="#handleUpdate"/>
            <Button text="Delete" onAction="#handleDelete"/>
            <Button text="Clear" onAction="#handleClear"/>
        </HBox>

        <Label fx:id="lblMessage"/>
    </VBox>

    <!-- ===== TABLE ===== -->
    <TableView fx:id="roleTable" prefHeight="300">

        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colName" text="Role Name" prefWidth="150"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
            <TableColumn fx:id="colDashboard" text="Dashboard" prefWidth="150"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
        </columns>

    </TableView>

</VBox>